# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to message the bot
TELEGRAM_ALLOWED_USERS=

# Optional: Override Claude CLI path (defaults to 'claude' on PATH)
# CLAUDE_PATH=/usr/local/bin/claude

# Optional: Whisper model for voice transcription (default: base)
# WHISPER_MODEL=base
