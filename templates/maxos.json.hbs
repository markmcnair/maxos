{
  "identity": {
    "name": "{{agentName}}",
    "emoji": "{{emoji}}",
    "timezone": "{{timezone}}"
  },
  "engine": {
    "model": "opus",
    "permissionMode": "bypassPermissions",
    "allowedTools": ["Read", "Write", "Edit", "Bash", "Grep", "Glob", "WebSearch", "WebFetch", "Agent", "mcp__*"],
    "maxOneShotTimeout": 600000,
    "watchdogTimeout": 600000,
    "responseTimeout": 600000
  },
  "channels": {
    {{#if telegramToken}}
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowedUsers": [{{#each telegramUsers}}"{{this}}"{{#unless @last}},{{/unless}}{{/each}}],
      "dmPolicy": "allowlist",
      "forumTopics": false
    }
    {{/if}}
  },
  "sessions": {
    "routing": [{ "default": true, "session": "main" }],
    "reset": { "daily": "04:00" },
    "identityLinks": {}
  },
  "scheduler": {
    "enabled": true,
    "heartbeatFile": "workspace/HEARTBEAT.md",
    "maxConcurrentTasks": 3,
    "circuitBreakerThreshold": 3,
    "protectedWindows": [
      { "name": "sleep", "start": "22:00", "end": "06:00" }
    ]
  },
  "reliability": {
    "stateSnapshotInterval": 30000,
    "crashJournalMaxEntries": 100,
    "healthCheckPort": 18790,
    "autoRestart": true
  }
}
