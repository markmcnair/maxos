{
  "permissions": {
    "allow": ["Bash", "Read", "Write", "Edit", "WebFetch", "WebSearch", "mcp__*"]
  },
  "hooks": {
    "PreCompact": [{
      "hooks": [{
        "type": "prompt",
        "prompt": "Context is about to be compacted. Write a thorough summary to today's daily journal at memory/YYYY-MM-DD.md (use today's actual date). Include: key decisions, tasks done/in-progress, commitments, current discussion topic. Append only — do not create empty checkpoint entries."
      }]
    }],
    "PostCompact": [{
      "hooks": [{
        "type": "command",
        "command": "{{maxosHome}}/hooks/post-compact-inject.sh"
      }]
    }]
  }
}
